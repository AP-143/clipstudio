# ClipStudio environment configuration
# Groq API key is supplied per-request from the browser via the X-Groq-Key
# header and is NEVER stored server-side. This file holds infra-level config only.

# Max number of jobs processed concurrently (semaphore)
MAX_CONCURRENT_JOBS=2

# Auto-delete finished jobs after N hours (1 / 6 / 24 / 0 = never)
JOB_AUTO_DELETE_HOURS=24

# Mark stuck jobs as failed after this many hours on startup
JOB_STUCK_HOURS=2

# Whisper model + device (auto = cuda if available else cpu)
WHISPER_MODEL=medium
WHISPER_DEVICE=auto

# Frontend -> backend base URL
VITE_API_BASE=http://localhost:8000
